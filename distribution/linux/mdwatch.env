# /etc/default/mdwatch
# Required:
COMPOSE_DIR=/absolute/path/to/docker-compose

# Optional:
ENV_FILE=/absolute/path/to/docker-compose/.env.runtime
# If not set, MARKDOWN_DIR is read from ENV_FILE.
# MARKDOWN_DIR=/absolute/path/to/markdown
DEBOUNCE_MS=800
RECONCILE_SEC=600
LOG_LEVEL=info
WATCH_SHELL=sh
MDWATCH_BIN=/usr/bin/mdwatch

# Optional custom build command, defaults to docker compose run hugo-builder:
# BUILD_CMD=./build.sh .env.runtime
